<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    
    <h1>Articles</h1>

    <ul>
        <% allArticles.forEach(article => { %>
            <li>
                <h2><%= article.title %></h2>
                <p><%= article.description %></p>
                <p>Likes: <%= article.likes %></p>
            </li>
        <% }) %>


</body>
</html>